# =============================================================================
# CubbyCove Environment Variables — NEVER commit the real .env to git!
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Appwrite Project ---
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here

# --- Admin API Key (server-side / setup scripts ONLY — never expose in frontend) ---
# Rotate regularly: Console → Settings → API Keys
APPWRITE_API_KEY=your_api_key_here

# --- Appwrite Function Env Vars (set in Appwrite Console → Functions → GeminiFilter → Variables) ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
